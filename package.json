{
  "name": "polls",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "backend": "npm run --workspace=backend",
    "frontend": "npm run --workspace=frontend",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspace=backend",
    "check:ts": "npm run check:ts --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "start:dev": "npm run start:dev --workspace=backend"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
